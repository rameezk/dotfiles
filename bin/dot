#!/usr/bin/env zsh

DOTFILES_DIR="$HOME/.dotfiles"
HOSTNAME="rameezk-macbook"

function main {

    function _usage {
        echo "Usage: dot COMMAND [FLAGS...] [ARGS...]"
        echo
        echo "Available commands:"
        echo "  rebuild|re                     Rebuild system"
        echo "  new-machine                    Setup system for new machine"
        echo "  install-nix-package-manager    Install Nix package manager"
        echo "  install-nix-darwin             Install Nix Darwin"
        echo "  install-nix-flakes             Install Nix Flakes"
        echo "  source-nix-env-vars            Source Nix environment variables (for emergencies only)"
    }

    function _rebuild {
        cd $DOTFILES_DIR

        echo "Checking for changes"
        if git diff --quiet && git diff --cached --quiet; then
            echo "Rebuilding system"
            nix build .\#darwinConfigurations.$HOSTNAME.system
            ./result/sw/bin/darwin-rebuild switch --flake .\#$HOSTNAME
        else
            echo "There are uncommitted files. Please commit before rebuilding."
            exit 1
        fi
    }

    function _install_nix_flakes {
        . $HOME/.nix-profile/etc/profile.d/nix.sh
        nix-env -iA nixpkgs.nixFlakes
    }

    function _rollback {
        echo "Rolling back system"
        cd $DOTFILES_DIR
    }

    function _install_nix_package_manager {
        echo "Installing Nix package manager"
        echo "Assuming fresh install. I am unable to check if nix already exists yet."
        sh <(curl -L https://nixos.org/nix/install) --darwin-use-unencrypted-nix-store-volume
    }

    function _install_nix_darwin {
        echo "Installing Nix Darwin"
        echo "Assuming fresh install. I am unable to check if nix-darwin already exists."
        cd $DOTFILES_DIR
        . $HOME/.nix-profile/etc/profile.d/nix.sh
        nix-build https://github.com/LnL7/nix-darwin/archive/master.tar.gz -A installer
        ./result/bin/darwin-installer
    }

    function _source_nix_env_vars {
        echo "Copy and run below command."
        echo ". $HOME/.nix-profile/etc/profile.d/nix.sh"
    }

    function _setup_system_for_new_machine {
        echo "Setting up system for new machine"
        _install_nix_package_manager
        _install_nix_darwin
        _install_nix_flakes
        echo "Done. Reboot terminal."
    }

    cmd="$1"
    [[ $# > 0 ]] && shift
    case "$cmd" in
        rebuild|re) _rebuild ;;
        new-machine) _setup_system_for_new_machine ;;
        install-nix-package-manager) _install_nix_package_manager ;;
        install-nix-darwin) _install_nix_darwin ;;
        install-nix-flakes) _install_nix_flakes ;;
        source-nix-env-vars) _source_nix_env_vars ;;
        h|help|-h|--help) _usage ;;
        "") _usage ;;
    esac
}

main "$@"