#!/usr/bin/env zsh

DOTFILES_DIR="$HOME/.dotfiles"

function main {

    function _usage {
        echo "Usage: dot COMMAND [FLAGS...] [ARGS...]"
        echo
        echo "Available commands:"
        echo "  build|b            Build system"
        echo "  check|ch           Check system before building"
        echo "  switch|sw          Switch to latest config"
    }

    function _build {
        echo "Building system"
        cd $DOTFILES_DIR
        nix --experimental-features 'flakes nix-command' build ".#homeManagerConfigurations.rivendell.activationPackage"
    }

    function _check {
        echo "Checking system"
        cd $DOTFILES_DIR
        nix --experimental-features 'flakes nix-command' flake check 
    }

    function _switch {
        echo "Switching system"
        cd $DOTFILES_DIR
        ./result/activate
    }

    cmd="$1"
    [[ $# > 0 ]] && shift
    case "$cmd" in
        build|b) _build ;;
        check|ch) _check ;;
        switch|sw) _switch ;;
        h|help|-h|--help) _usage ;;
        "") _usage ;;
    esac
}

main "$@"